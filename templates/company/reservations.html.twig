{% extends 'base.html.twig' %}
{% block title %}Mes Réservations - {{ app.user.companyName }}{% endblock %}

{% block sidebar %}
<aside class="sidebar">
    <div class="sidebar-header">
        <a href="{{ path('company_dashboard') }}" class="sidebar-brand">
            <div class="logo">🚌</div>
            <div class="brand-text">
                <span class="title">{{ app.user.companyName }}</span>
                <span class="subtitle">Espace Compagnie</span>
            </div>
        </a>
    </div>
    <div class="sidebar-user">
        <img src="https://ui-avatars.com/api/?name={{ app.user.companyName|url_encode }}&background=14B53A&color=fff" alt="">
        <div class="user-info">
            <div class="name">{{ app.user.firstName }} {{ app.user.lastName }}</div>
            <div class="role">{{ app.user.companyName }}</div>
        </div>
    </div>
    <ul class="sidebar-menu">
        <li><a href="{{ path('company_dashboard') }}"><i class="fas fa-home"></i><span>Tableau de Bord</span></a></li>
        <li><a href="{{ path('company_trips') }}"><i class="fas fa-bus"></i><span>Mes Trajets</span></a></li>
        <li><a href="{{ path('company_reservations') }}" class="active"><i class="fas fa-ticket-alt"></i><span>Mes Réservations</span></a></li>
        <li><a href="{{ path('company_statistics') }}"><i class="fas fa-chart-bar"></i><span>Statistiques</span></a></li>
        <li><a href="{{ path('company_messages') }}"><i class="fas fa-envelope"></i><span>Messagerie</span></a></li>
        <li><a href="{{ path('company_settings') }}"><i class="fas fa-cog"></i><span>Paramètres</span></a></li>
        <li><a href="{{ path('company_profile') }}"><i class="fas fa-user-cog"></i><span>Mon Profil</span></a></li>
    </ul>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="btn-logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a>
    </div>
</aside>
{% endblock %}

{% block body %}
<h1 class="page-title">Mes Réservations</h1>

{# Filtres #}
<div class="card" style="margin-bottom:20px;">
    <div class="card-body" style="padding:20px;">
        <form method="get" action="{{ path('company_reservations') }}" style="display:flex;gap:15px;flex-wrap:wrap;align-items:flex-end;">
            <div class="filter-group" style="flex:1;min-width:200px;">
                <label>Rechercher</label>
                <input type="text" name="search" value="{{ search }}" placeholder="Réf, nom, téléphone...">
            </div>
            <div class="filter-group" style="min-width:160px;">
                <label>Statut</label>
                <select name="status">
                    <option value="">Tous</option>
                    <option value="pending" {% if status == 'pending' %}selected{% endif %}>En attente</option>
                    <option value="confirmed" {% if status == 'confirmed' %}selected{% endif %}>Confirmé</option>
                    <option value="cancelled" {% if status == 'cancelled' %}selected{% endif %}>Annulé</option>
                </select>
            </div>
            <div class="filter-group" style="min-width:160px;">
                <label>Date de voyage</label>
                <input type="date" name="travel_date" id="travelDate" value="{{ travel_date }}">
            </div>
            <div style="display:flex;gap:8px;">
                <button type="button" onclick="setToday()" class="btn btn-warning"><i class="fas fa-calendar-day"></i> Aujourd'hui</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Filtrer</button>
                <a href="{{ path('company_reservations') }}" class="btn btn-danger"><i class="fas fa-times"></i> Effacer</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3><i class="fas fa-ticket-alt"></i> Réservations ({{ reservations|length }})</h3>
    </div>
    <div class="card-body" style="padding:0;">
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Réf</th>
                        <th>Passager</th>
                        <th>Téléphone</th>
                        <th>Trajet</th>
                        <th>Date Voyage</th>
                        <th>Passagers</th>
                        <th>Montant</th>
                        <th>Commission</th>
                        <th>Statut</th>
                        <th>Date Résa</th>
                    </tr>
                </thead>
                <tbody>
                {% for r in reservations %}
                    <tr>
                        <td><code style="font-size:12px;">{{ r.reservationId }}</code></td>
                        <td><strong>{{ r.passengerFirstName }} {{ r.passengerLastName }}</strong></td>
                        <td>{{ r.passengerPhone }}</td>
                        <td>{{ r.trip.departureCity }} → {{ r.trip.arrivalCity }}</td>
                        <td>{{ r.travelDate|date('d/m/Y') }}</td>
                        <td style="text-align:center;">{{ r.numPassengers }}</td>
                        <td><strong>{{ r.totalPrice|number_format(0, ',', ' ') }} F</strong></td>
                        <td style="color:#e67e22;">{{ r.commissionAmount|number_format(0, ',', ' ') }} F</td>
                        <td>
                            {% if r.status == 'confirmed' %}<span class="badge badge-success">Confirmé</span>
                            {% elseif r.status == 'cancelled' %}<span class="badge badge-danger">Annulé</span>
                            {% else %}<span class="badge badge-warning">En attente</span>{% endif %}
                        </td>
                        <td>{{ r.createdAt|date('d/m/Y H:i') }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="10" style="text-align:center;color:#999;padding:30px;">Aucune réservation trouvée.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function setToday() {
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('travelDate').value = today;
    document.querySelector('form').submit();
}
</script>
{% endblock %}
