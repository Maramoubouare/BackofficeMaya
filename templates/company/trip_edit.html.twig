{% extends 'base.html.twig' %}
{% block title %}Modifier un Trajet - {{ app.user.companyName }}{% endblock %}

{% block sidebar %}
<aside class="sidebar">
    <div class="sidebar-header">
        <a href="{{ path('company_dashboard') }}" class="sidebar-brand">
            <div class="logo">🚌</div>
            <div class="brand-text">
                <span class="title">{{ app.user.companyName }}</span>
                <span class="subtitle">Espace Compagnie</span>
            </div>
        </a>
    </div>
    <div class="sidebar-user">
        <img src="https://ui-avatars.com/api/?name={{ app.user.companyName|url_encode }}&background=14B53A&color=fff" alt="">
        <div class="user-info">
            <div class="name">{{ app.user.firstName }} {{ app.user.lastName }}</div>
            <div class="role">{{ app.user.companyName }}</div>
        </div>
    </div>
    <ul class="sidebar-menu">
        <li><a href="{{ path('company_dashboard') }}"><i class="fas fa-home"></i><span>Tableau de Bord</span></a></li>
        <li><a href="{{ path('company_trips') }}" class="active"><i class="fas fa-bus"></i><span>Mes Trajets</span></a></li>
        <li><a href="{{ path('company_reservations') }}"><i class="fas fa-ticket-alt"></i><span>Mes Réservations</span></a></li>
        <li><a href="{{ path('company_statistics') }}"><i class="fas fa-chart-bar"></i><span>Statistiques</span></a></li>
        <li><a href="{{ path('company_messages') }}"><i class="fas fa-envelope"></i><span>Messagerie</span></a></li>
        <li><a href="{{ path('company_settings') }}"><i class="fas fa-cog"></i><span>Paramètres</span></a></li>
        <li><a href="{{ path('company_profile') }}"><i class="fas fa-user-cog"></i><span>Mon Profil</span></a></li>
    </ul>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="btn-logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a>
    </div>
</aside>
{% endblock %}

{% block body %}
<h1 class="page-title">Modifier le Trajet</h1>

{% for msg in app.flashes('success') %}
    <div style="background:#d4edda;color:#155724;padding:15px 20px;border-radius:8px;margin-bottom:20px;border-left:4px solid #28a745;font-weight:600;">
        <i class="fas fa-check-circle"></i> {{ msg }}
    </div>
{% endfor %}

<div class="card" style="max-width:850px;">
    <div class="card-header">
        <h3><i class="fas fa-edit"></i> {{ trip.departureCity }} → {{ trip.arrivalCity }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ path('company_trip_edit', {id: trip.id}) }}">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

                <div class="filter-group">
                    <label>Ville de Départ *</label>
                    <select name="departure_city" required>
                        {% for city in ['Bamako','Sikasso','Mopti','Koutiala','Kayes','Ségou','Gao','Kidal','Tombouctou','San'] %}
                            <option value="{{ city }}" {% if trip.departureCity == city %}selected{% endif %}>{{ city }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-group">
                    <label>Ville d'Arrivée *</label>
                    <select name="arrival_city" required>
                        {% for city in ['Bamako','Sikasso','Mopti','Koutiala','Kayes','Ségou','Gao','Kidal','Tombouctou','San'] %}
                            <option value="{{ city }}" {% if trip.arrivalCity == city %}selected{% endif %}>{{ city }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-group">
                    <label>Heure de Départ *</label>
                    <input type="time" name="departure_time" required value="{{ trip.departureTime|date('H:i') }}">
                </div>

                <div class="filter-group">
                    <label>Heure d'Arrivée *</label>
                    <input type="time" name="arrival_time" required value="{{ trip.arrivalTime|date('H:i') }}">
                </div>

                <div class="filter-group">
                    <label>Durée *</label>
                    <input type="text" name="duration" required value="{{ trip.duration }}" placeholder="3h30">
                </div>

                <div class="filter-group">
                    <label>Prix (FCFA) *</label>
                    <input type="number" name="price" required min="0" step="100" value="{{ trip.price }}">
                </div>

                <div class="filter-group">
                    <label>Nombre de Places *</label>
                    <input type="number" name="total_seats" required min="1" value="{{ trip.totalSeats }}">
                </div>

                <div class="filter-group">
                    <label>Type de Véhicule</label>
                    <select name="vehicle_type">
                        {% for vtype in ['Bus', 'Minibus', '4x4'] %}
                            <option value="{{ vtype }}" {% if trip.vehicleType == vtype %}selected{% endif %}>{{ vtype }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div style="margin-bottom:20px;">
                <label style="font-weight:600;margin-bottom:10px;display:block;">Jours de Circulation</label>
                <div style="display:flex;gap:10px;flex-wrap:wrap;">
                    {% for day, label in {1:'Lun', 2:'Mar', 3:'Mer', 4:'Jeu', 5:'Ven', 6:'Sam', 7:'Dim'} %}
                        <label style="display:flex;align-items:center;gap:6px;background:#f5f5f5;padding:8px 14px;border-radius:8px;cursor:pointer;">
                            <input type="checkbox" name="days_of_week[]" value="{{ day }}"
                                {% if day in trip.daysOfWeek %}checked{% endif %}> {{ label }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            <div style="display:flex;gap:20px;margin-bottom:20px;">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                    <input type="checkbox" name="has_ac" value="1" {% if trip.hasAC %}checked{% endif %}>
                    <i class="fas fa-snowflake" style="color:#17a2b8;"></i> Climatisé
                </label>
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                    <input type="checkbox" name="has_break" value="1" id="hasBreakCheck" {% if trip.hasBreak %}checked{% endif %}>
                    <i class="fas fa-coffee" style="color:#ffc107;"></i> Pause en route
                </label>
            </div>

            <div class="filter-group" id="breakLocationDiv" style="{% if not trip.hasBreak %}display:none;{% endif %}max-width:400px;margin-bottom:20px;">
                <label>Lieu de la Pause</label>
                <input type="text" name="break_location" value="{{ trip.breakLocation }}" placeholder="Ex: Ségou">
            </div>

            <div style="display:flex;gap:12px;justify-content:flex-end;">
                <a href="{{ path('company_trips') }}" class="btn btn-danger">
                    <i class="fas fa-times"></i> Annuler
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save"></i> Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.getElementById('hasBreakCheck').addEventListener('change', function() {
    document.getElementById('breakLocationDiv').style.display = this.checked ? 'block' : 'none';
});
</script>
{% endblock %}
