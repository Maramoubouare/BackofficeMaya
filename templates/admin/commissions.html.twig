{% extends 'base.html.twig' %}

{% block title %}Commissions - MAYA Admin{% endblock %}

{% block body %}
<nav class="main-header navbar navbar-expand navbar-white navbar-light">
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#"><i class="fas fa-bars"></i></a>
        </li>
    </ul>
    <ul class="navbar-nav ml-auto">
        <li class="nav-item">
            <a class="nav-link" href="{{ path('app_logout') }}">
                <i class="fas fa-sign-out-alt"></i> Déconnexion
            </a>
        </li>
    </ul>
</nav>

<aside class="main-sidebar sidebar-dark-primary elevation-4">
    <a href="{{ path('admin_dashboard') }}" class="brand-link">
        <i class="fas fa-bus brand-image"></i>
        <span class="brand-text font-weight-light">MAYA ADMIN</span>
    </a>
    <div class="sidebar">
        <nav class="mt-2">
            <ul class="nav nav-pills nav-sidebar flex-column">
                <li class="nav-item">
                    <a href="{{ path('admin_dashboard') }}" class="nav-link">
                        <i class="nav-icon fas fa-tachometer-alt"></i>
                        <p>Dashboard</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_companies') }}" class="nav-link">
                        <i class="nav-icon fas fa-building"></i>
                        <p>Compagnies</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_trips') }}" class="nav-link">
                        <i class="nav-icon fas fa-route"></i>
                        <p>Trajets</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_reservations') }}" class="nav-link">
                        <i class="nav-icon fas fa-ticket-alt"></i>
                        <p>Réservations</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_commissions') }}" class="nav-link active">
                        <i class="nav-icon fas fa-money-bill-wave"></i>
                        <p>Commissions</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_statistics') }}" class="nav-link">
                        <i class="nav-icon fas fa-chart-bar"></i>
                        <p>Statistiques</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_users') }}" class="nav-link">
                        <i class="nav-icon fas fa-users"></i>
                        <p>Utilisateurs</p>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</aside>

<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <h1 class="m-0"><i class="fas fa-money-bill-wave"></i> Gestion des Commissions</h1>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <!-- Résumé global -->
            <div class="row">
                <div class="col-lg-4">
                    <div class="info-box bg-success">
                        <span class="info-box-icon"><i class="fas fa-money-bill-wave"></i></span>
                        <div class="info-box-content">
                            <span class="info-box-text">Total Commissions MAYA</span>
                            {% set totalCommissions = 0 %}
                            {% for commission in commissions %}
                                {% set totalCommissions = totalCommissions + commission.total_commission %}
                            {% endfor %}
                            <span class="info-box-number">{{ (totalCommissions / 1000)|number_format(1) }}K FCFA</span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="info-box bg-info">
                        <span class="info-box-icon"><i class="fas fa-building"></i></span>
                        <div class="info-box-content">
                            <span class="info-box-text">Total Compagnies</span>
                            {% set totalCompany = 0 %}
                            {% for commission in commissions %}
                                {% set totalCompany = totalCompany + commission.total_company %}
                            {% endfor %}
                            <span class="info-box-number">{{ (totalCompany / 1000000)|number_format(2) }}M FCFA</span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="info-box bg-warning">
                        <span class="info-box-icon"><i class="fas fa-receipt"></i></span>
                        <div class="info-box-content">
                            <span class="info-box-text">Nombre de Transactions</span>
                            {% set totalTransactions = 0 %}
                            {% for commission in commissions %}
                                {% set totalTransactions = totalTransactions + commission.nb_transactions %}
                            {% endfor %}
                            <span class="info-box-number">{{ totalTransactions }}</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Table des commissions par compagnie -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-table"></i> Commissions par Compagnie
                    </h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover text-nowrap">
                        <thead>
                            <tr>
                                <th>Compagnie</th>
                                <th>Nb Transactions</th>
                                <th>Revenus Total</th>
                                <th>Commission MAYA</th>
                                <th>Part Compagnie</th>
                                <th>Taux Moyen</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for commission in commissions %}
                            <tr>
                                <td>
                                    <strong>{{ commission.companyName }}</strong>
                                </td>
                                <td>
                                    <span class="badge badge-primary">{{ commission.nb_transactions }}</span>
                                </td>
                                <td>
                                    <strong>{{ (commission.total_commission + commission.total_company)|number_format(0, ',', ' ') }} FCFA</strong>
                                </td>
                                <td>
                                    <span class="badge badge-success">
                                        {{ commission.total_commission|number_format(0, ',', ' ') }} FCFA
                                    </span>
                                </td>
                                <td>
                                    <span class="badge badge-info">
                                        {{ commission.total_company|number_format(0, ',', ' ') }} FCFA
                                    </span>
                                </td>
                                <td>
                                    {% set avgRate = (commission.total_commission / (commission.total_commission + commission.total_company) * 100) %}
                                    {{ avgRate|number_format(2) }}%
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-info" title="Détails">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="btn btn-sm btn-success" title="Historique paiements">
                                        <i class="fas fa-history"></i>
                                    </button>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="7" class="text-center">
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle"></i> Aucune commission enregistrée.
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr class="bg-light">
                                <th>TOTAL</th>
                                <th>{{ totalTransactions }}</th>
                                <th>{{ ((totalCommissions + totalCompany) / 1000000)|number_format(2) }}M FCFA</th>
                                <th>{{ (totalCommissions / 1000)|number_format(0) }}K FCFA</th>
                                <th>{{ (totalCompany / 1000000)|number_format(2) }}M FCFA</th>
                                <th>-</th>
                                <th>-</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </section>
</div>

<footer class="main-footer">
    <strong>Copyright &copy; 2025 MAYA Transport.</strong> Tous droits réservés.
</footer>
{% endblock %}