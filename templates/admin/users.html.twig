{% extends 'base.html.twig' %}

{% block title %}Utilisateurs - Maya{% endblock %}

{% block body %}
<h1 class="page-title">Gestion des Utilisateurs</h1>

<div style="display: flex; gap: 12px; margin-bottom: 25px;">
    <button onclick="openAddUserModal()" class="btn btn-success">
        <i class="fas fa-plus"></i> Ajouter Utilisateur
    </button>
</div>

{# STATS CARDS #}
<div class="stats-grid">
    <div class="stat-card blue">
        <div class="icon"><i class="fas fa-users"></i></div>
        <div class="content">
            <div class="number">{{ users|length }}</div>
            <div class="label">Total Utilisateurs</div>
        </div>
    </div>
    <div class="stat-card green">
        <div class="icon"><i class="fas fa-building"></i></div>
        <div class="content">
            {% set companyCount = 0 %}
            {% for user in users %}
                {% if 'ROLE_COMPANY' in user.roles %}
                    {% set companyCount = companyCount + 1 %}
                {% endif %}
            {% endfor %}
            <div class="number">{{ companyCount }}</div>
            <div class="label">Compagnies</div>
        </div>
    </div>
    <div class="stat-card orange">
        <div class="icon"><i class="fas fa-headset"></i></div>
        <div class="content">
            {% set clientCount = 0 %}
            {% for user in users %}
                {% if 'ROLE_SERVICE_CLIENT' in user.roles %}
                    {% set clientCount = clientCount + 1 %}
                {% endif %}
            {% endfor %}
            <div class="number">{{ clientCount }}</div>
            <div class="label">Service Client</div>
        </div>
    </div>
    <div class="stat-card purple">
        <div class="icon"><i class="fas fa-user-shield"></i></div>
        <div class="content">
            {% set adminCount = 0 %}
            {% for user in users %}
                {% if 'ROLE_ADMIN' in user.roles %}
                    {% set adminCount = adminCount + 1 %}
                {% endif %}
            {% endfor %}
            <div class="number">{{ adminCount }}</div>
            <div class="label">Administrateurs</div>
        </div>
    </div>
</div>

{# FILTRES #}
<form method="get">
    <div class="filters-bar">
        <div class="filters-row">
            <div class="filter-group">
                <label>Rôle :</label>
                <select name="role">
                    <option value="">Tous</option>
                    <option value="ROLE_ADMIN" {{ role == 'ROLE_ADMIN' ? 'selected' : '' }}>Administrateur</option>
                    <option value="ROLE_COMPANY" {{ role == 'ROLE_COMPANY' ? 'selected' : '' }}>Compagnie</option>
                    <option value="ROLE_SERVICE_CLIENT" {{ role == 'ROLE_SERVICE_CLIENT' ? 'selected' : '' }}>Service Client</option>
                </select>
            </div>

            <div class="filter-group">
                <label>Rechercher :</label>
                <input type="text" name="search" value="{{ search }}" placeholder="Nom, email...">
            </div>

            <button type="submit" class="btn btn-primary" style="align-self: flex-end;">
                <i class="fas fa-search"></i> Rechercher
            </button>
        </div>
    </div>
</form>

{# TABLEAU #}
<div class="card">
    <div class="card-header">
        <h3><i class="fas fa-users"></i> Liste ({{ users|length }})</h3>
    </div>
    <div class="card-body" style="padding: 0;">
        <table>
            <thead>
                <tr>
                    <th>NOM</th>
                    <th>EMAIL</th>
                    <th>RÔLE</th>
                    <th>COMPAGNIE</th>
                    <th>STATUT</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td><strong>{{ user.firstName }} {{ user.lastName }}</strong></td>
                    <td>{{ user.email }}</td>
                    <td>
                        {% if 'ROLE_ADMIN' in user.roles %}
                            <span class="badge danger">ADMINISTRATEUR</span>
                        {% elseif 'ROLE_COMPANY' in user.roles %}
                            <span class="badge success">COMPAGNIE</span>
                        {% elseif 'ROLE_SERVICE_CLIENT' in user.roles %}
                            <span class="badge info">SERVICE CLIENT</span>
                        {% else %}
                            <span class="badge secondary">USER</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if user.companyName %}
                            <strong>{{ user.companyName }}</strong>
                        {% else %}
                            <span style="color: #95a5a6;">-</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if user.isActive %}
                            <span class="badge success">Actif</span>
                        {% else %}
                            <span class="badge danger">Inactif</span>
                        {% endif %}
                    </td>
                    <td>
                        <div style="display: flex; gap: 6px;">
                            <button 
                                onclick="editUser({{ user.id }})" 
                                class="btn btn-sm btn-primary" 
                                title="Modifier"
                            >
                                <i class="fas fa-edit"></i>
                            </button>
                            <button 
                                onclick="toggleUser({{ user.id }})" 
                                class="btn btn-sm btn-warning" 
                                title="Activer/Désactiver"
                            >
                                <i class="fas fa-power-off"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" style="text-align: center; padding: 40px; color: #7f8c8d;">
                        <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 15px; display: block;"></i>
                        Aucun utilisateur trouvé
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# MODAL CHOIX TYPE UTILISATEUR #}
<div id="addUserModal" class="modal">
    <div class="modal-content" style="max-width: 500px;">
        <div class="modal-header">
            <h3><i class="fas fa-plus"></i> Ajouter un Utilisateur</h3>
            <button onclick="closeAddUserModal()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body">
            <p style="margin-bottom: 25px; color: #7f8c8d;">Choisissez le type d'utilisateur à créer :</p>
            
            <div style="display: grid; gap: 15px;">
                <a href="{{ path('admin_company_create') }}" class="choice-card">
                    <div class="choice-icon" style="background: linear-gradient(135deg, #14B53A, #0e8c2d);">
                        <i class="fas fa-building"></i>
                    </div>
                    <div class="choice-content">
                        <h4>Compagnie de Transport</h4>
                        <p>Créer une nouvelle compagnie de bus</p>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </a>
                
                <button onclick="createServiceClient()" class="choice-card" style="border: 2px solid #e0e0e0; background: white;">
                    <div class="choice-icon" style="background: linear-gradient(135deg, #3498db, #2980b9);">
                        <i class="fas fa-headset"></i>
                    </div>
                    <div class="choice-content">
                        <h4>Agent Service Client</h4>
                        <p>Créer un compte service client</p>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

{# MODAL MODIFICATION #}
<div id="editModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-edit"></i> Modifier l'Utilisateur</h3>
            <button onclick="closeEditModal()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body">
            <form id="editForm">
                <input type="hidden" id="editUserId">
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="form-group">
                        <label>Prénom</label>
                        <input type="text" id="editFirstName" class="form-control" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Nom</label>
                        <input type="text" id="editLastName" class="form-control" required>
                    </div>
                </div>
                
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="editEmail" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label>Téléphone</label>
                    <input type="text" id="editPhone" class="form-control">
                </div>
                
                <div class="form-group" id="companyNameGroup" style="display: none;">
                    <label>Nom de la Compagnie</label>
                    <input type="text" id="editCompanyName" class="form-control">
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button onclick="closeEditModal()" class="btn btn-secondary">
                <i class="fas fa-times"></i> Annuler
            </button>
            <button onclick="saveEdit()" class="btn btn-success">
                <i class="fas fa-save"></i> Enregistrer
            </button>
        </div>
    </div>
</div>

{# MODAL SERVICE CLIENT #}
<div id="serviceClientModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-headset"></i> Créer Agent Service Client</h3>
            <button onclick="closeServiceClientModal()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body">
            <form id="serviceClientForm">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="form-group">
                        <label>Prénom *</label>
                        <input type="text" id="scFirstName" class="form-control" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Nom *</label>
                        <input type="text" id="scLastName" class="form-control" required>
                    </div>
                </div>
                
                <div class="form-group">
                    <label>Email *</label>
                    <input type="email" id="scEmail" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label>Téléphone</label>
                    <input type="text" id="scPhone" class="form-control">
                </div>
                
                <div class="form-group">
                    <label>Mot de passe *</label>
                    <input type="password" id="scPassword" class="form-control" required>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button onclick="closeServiceClientModal()" class="btn btn-secondary">
                <i class="fas fa-times"></i> Annuler
            </button>
            <button onclick="saveServiceClient()" class="btn btn-success">
                <i class="fas fa-save"></i> Créer
            </button>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
// MODAL AJOUT UTILISATEUR
function openAddUserModal() {
    document.getElementById('addUserModal').style.display = 'block';
}

function closeAddUserModal() {
    document.getElementById('addUserModal').style.display = 'none';
}

function createServiceClient() {
    closeAddUserModal();
    document.getElementById('serviceClientModal').style.display = 'block';
}

// MODAL SERVICE CLIENT
function closeServiceClientModal() {
    document.getElementById('serviceClientModal').style.display = 'none';
}

function saveServiceClient() {
    const data = {
        first_name: document.getElementById('scFirstName').value,
        last_name: document.getElementById('scLastName').value,
        email: document.getElementById('scEmail').value,
        phone: document.getElementById('scPhone').value,
        password: document.getElementById('scPassword').value
    };
    
    fetch('/admin/user/create-service-client', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(res => res.json())
    .then(result => {
        if (result.success) {
            alert('✅ ' + result.message);
            location.reload();
        } else {
            alert('❌ ' + result.message);
        }
    })
    .catch(err => {
        console.error(err);
        alert('❌ Erreur lors de la création');
    });
}

// MODAL ÉDITION
function editUser(id) {
    fetch('/admin/user/' + id + '/data')
        .then(res => res.json())
        .then(data => {
            document.getElementById('editUserId').value = data.id;
            document.getElementById('editFirstName').value = data.firstName;
            document.getElementById('editLastName').value = data.lastName;
            document.getElementById('editEmail').value = data.email;
            document.getElementById('editPhone').value = data.phone || '';
            
            if (data.companyName) {
                document.getElementById('companyNameGroup').style.display = 'block';
                document.getElementById('editCompanyName').value = data.companyName;
            } else {
                document.getElementById('companyNameGroup').style.display = 'none';
            }
            
            document.getElementById('editModal').style.display = 'block';
        })
        .catch(err => {
            console.error(err);
            alert('❌ Erreur lors du chargement');
        });
}

function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
}

function saveEdit() {
    const id = document.getElementById('editUserId').value;
    const data = {
        first_name: document.getElementById('editFirstName').value,
        last_name: document.getElementById('editLastName').value,
        email: document.getElementById('editEmail').value,
        phone: document.getElementById('editPhone').value,
        company_name: document.getElementById('editCompanyName').value
    };
    
    fetch('/admin/user/' + id + '/edit', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(res => res.json())
    .then(result => {
        if (result.success) {
            alert('✅ ' + result.message);
            location.reload();
        } else {
            alert('❌ ' + result.message);
        }
    })
    .catch(err => {
        console.error(err);
        alert('❌ Erreur lors de la modification');
    });
}

// TOGGLE
function toggleUser(id) {
    if (!confirm('Voulez-vous changer le statut de cet utilisateur ?')) {
        return;
    }
    
    fetch('/admin/user/' + id + '/toggle', {
        method: 'POST'
    })
    .then(res => res.json())
    .then(result => {
        if (result.success) {
            alert('✅ ' + result.message);
            location.reload();
        } else {
            alert('❌ ' + result.message);
        }
    })
    .catch(err => {
        console.error(err);
        alert('❌ Erreur');
    });
}

// FERMER MODALS AU CLIC EXTÉRIEUR
window.onclick = function(event) {
    const modals = ['addUserModal', 'editModal', 'serviceClientModal'];
    modals.forEach(modalId => {
        const modal = document.getElementById(modalId);
        if (event.target == modal) {
            modal.style.display = 'none';
        }
    });
}
</script>

<style>
.choice-card {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 20px;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    color: inherit;
}

.choice-card:hover {
    transform: translateX(5px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

.choice-icon {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 28px;
    flex-shrink: 0;
}

.choice-content {
    flex: 1;
}

.choice-content h4 {
    margin: 0 0 5px 0;
    font-size: 18px;
    color: #2c3e50;
}

.choice-content p {
    margin: 0;
    font-size: 14px;
    color: #7f8c8d;
}

.choice-card i.fa-chevron-right {
    color: #bdc3c7;
    font-size: 20px;
}

.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(0,0,0,0.5);
}

.modal-content {
    background-color: #fff;
    margin: 3% auto;
    border-radius: 10px;
    width: 90%;
    max-width: 700px;
    box-shadow: 0 5px 30px rgba(0,0,0,0.3);
}

.modal-header {
    padding: 20px 25px;
    background: linear-gradient(135deg, #14B53A, #0e8c2d);
    color: white;
    border-radius: 10px 10px 0 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.modal-header h3 {
    margin: 0;
    font-size: 20px;
}

.close-btn {
    background: none;
    border: none;
    color: white;
    font-size: 32px;
    cursor: pointer;
    line-height: 1;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.close-btn:hover {
    opacity: 0.7;
}

.modal-body {
    padding: 25px;
}

.modal-footer {
    padding: 20px 25px;
    background: #f5f5f5;
    border-radius: 0 0 10px 10px;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}

.form-group {
    margin-bottom: 15px;
}

.form-group label {
    display: block;
    font-weight: 600;
    margin-bottom: 8px;
    color: #2c3e50;
}

.form-control {
    width: 100%;
    padding: 10px 15px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 16px;
    transition: border-color 0.3s;
}

.form-control:focus {
    outline: none;
    border-color: #14B53A;
}
</style>
{% endblock %}
