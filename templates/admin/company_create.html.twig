{% extends 'base.html.twig' %}

{% block title %}Créer Compagnie - Maya{% endblock %}

{% block body %}
<h1 class="page-title">Créer une Compagnie</h1>

<div class="card" style="max-width: 900px;">
    <div class="card-header">
        <h3><i class="fas fa-plus-circle"></i> Informations de la Compagnie</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ path('admin_company_create') }}">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                <div class="filter-group" style="grid-column: 1 / -1;">
                    <label>Nom de la Compagnie *</label>
                    <input type="text" name="company_name" required placeholder="Ex: Somatra">
                </div>

                <div class="filter-group">
                    <label>Prénom du Gérant *</label>
                    <input type="text" name="first_name" required placeholder="Ex: Moussa">
                </div>

                <div class="filter-group">
                    <label>Nom du Gérant *</label>
                    <input type="text" name="last_name" required placeholder="Ex: TRAORE">
                </div>

                <div class="filter-group">
                    <label>Email *</label>
                    <input type="email" name="email" required placeholder="Ex: contact@somatra.ml">
                </div>

                <div class="filter-group">
                    <label>Téléphone *</label>
                    <input type="tel" name="phone" required placeholder="Ex: 76222222">
                </div>

                <div class="filter-group" style="grid-column: 1 / -1;">
                    <label>Mot de passe *</label>
                    <div style="display:flex;gap:10px;">
                        <input type="text" id="password" name="password" required placeholder="Saisir ou générer..." style="flex:1;font-family:monospace;">
                        <button type="button" onclick="generatePassword()" class="btn btn-warning" style="flex-shrink:0;">
                            <i class="fas fa-random"></i> Générer
                        </button>
                    </div>
                    <small style="color:#7f8c8d;margin-top:5px;display:block;">Minimum 8 caractères. Ce mot de passe sera affiché une seule fois après création.</small>
                </div>

                <div class="filter-group">
                    <label>Commission (%)</label>
                    <input type="number" name="commission_rate" value="2.00" step="0.01" min="0" max="100">
                </div>

                <div class="filter-group">
                    <label>Commission Min (FCFA)</label>
                    <input type="number" name="commission_min" value="300" step="50" min="0">
                </div>
            </div>

            <div style="padding: 15px; background: #e3f2fd; border-radius: 6px; margin-bottom: 20px; border-left: 4px solid #2196F3;">
                <strong><i class="fas fa-info-circle"></i> Informations :</strong>
                <ul style="margin: 10px 0 0 20px; padding: 0;">
                    <li>Un <strong>mot de passe temporaire</strong> sera généré automatiquement et affiché après la création</li>
                    <li>La compagnie pourra modifier son mot de passe après la première connexion</li>
                    <li>Les commissions peuvent être ajustées individuellement</li>
                </ul>
            </div>

            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <a href="{{ path('admin_companies') }}" class="btn btn-danger">
                    <i class="fas fa-times"></i> Annuler
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-check"></i> Créer la Compagnie
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function generatePassword() {
    const chars = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@#';
    let pwd = '';
    for (let i = 0; i < 10; i++) pwd += chars[Math.floor(Math.random() * chars.length)];
    document.getElementById('password').value = pwd;
}
</script>
{% endblock %}
