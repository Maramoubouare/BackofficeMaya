{% extends 'base.html.twig' %}

{% block title %}Modifier Trajet - Maya{% endblock %}

{% block body %}
<h1 class="page-title">Modifier le Trajet</h1>

<div class="card" style="max-width: 900px;">
    <div class="card-header">
        <h3><i class="fas fa-edit"></i> Modification : {{ trip.departureCity }} → {{ trip.arrivalCity }}</h3>
    </div>
    <div class="card-body">
        <form method="post" action="{{ path('admin_trip_edit', {id: trip.id}) }}">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                <div class="filter-group">
                    <label>Compagnie *</label>
                    <select name="company_id" required>
                        {% for company in companies %}
                            <option value="{{ company.id }}" {% if trip.company.id == company.id %}selected{% endif %}>
                                {{ company.companyName }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-group">
                    <label>Prix (FCFA) *</label>
                    <input type="number" name="price" required min="0" step="100" value="{{ trip.price }}">
                </div>

                <div class="filter-group">
                    <label>Ville de Départ *</label>
                    <input type="text" name="departure_city" required value="{{ trip.departureCity }}" list="cities">
                </div>

                <div class="filter-group">
                    <label>Ville d'Arrivée *</label>
                    <input type="text" name="arrival_city" required value="{{ trip.arrivalCity }}" list="cities">
                </div>

                <div class="filter-group">
                    <label>Heure Départ *</label>
                    <input type="time" name="departure_time" required value="{{ trip.departureTime|date('H:i') }}">
                </div>

                <div class="filter-group">
                    <label>Heure Arrivée *</label>
                    <input type="time" name="arrival_time" required value="{{ trip.arrivalTime|date('H:i') }}">
                </div>

                <div class="filter-group">
                    <label>Durée *</label>
                    <input type="text" name="duration" required value="{{ trip.duration }}">
                </div>

                <div class="filter-group">
                    <label>Places Total *</label>
                    <input type="number" name="total_seats" required min="1" value="{{ trip.totalSeats }}">
                </div>
            </div>

            <!-- JOURS DE LA SEMAINE -->
            <div class="filter-group" style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 10px; font-weight: 600;">Jours d'opération *</label>
                <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                    {% set tripDays = trip.daysOfWeek|default(['0','1','2','3','4','5','6']) %}
                    
                    <label class="checkbox-label">
                        <input type="checkbox" name="days[]" value="1" {% if '1' in tripDays or 1 in tripDays %}checked{% endif %}>
                        <span>Lundi</span>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="days[]" value="2" {% if '2' in tripDays or 2 in tripDays %}checked{% endif %}>
                        <span>Mardi</span>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="days[]" value="3" {% if '3' in tripDays or 3 in tripDays %}checked{% endif %}>
                        <span>Mercredi</span>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="days[]" value="4" {% if '4' in tripDays or 4 in tripDays %}checked{% endif %}>
                        <span>Jeudi</span>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="days[]" value="5" {% if '5' in tripDays or 5 in tripDays %}checked{% endif %}>
                        <span>Vendredi</span>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="days[]" value="6" {% if '6' in tripDays or 6 in tripDays %}checked{% endif %}>
                        <span>Samedi</span>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="days[]" value="0" {% if '0' in tripDays or 0 in tripDays %}checked{% endif %}>
                        <span>Dimanche</span>
                    </label>
                </div>
                <small style="color: #7f8c8d; display: block; margin-top: 8px;">
                    Sélectionnez les jours où ce trajet sera disponible
                </small>
            </div>

            <datalist id="cities">
                <option value="Bamako">
                <option value="Sikasso">
                <option value="Mopti">
                <option value="Koutiala">
                <option value="Kayes">
                <option value="Ségou">
                <option value="Gao">
                <option value="Kidal">
                <option value="Tombouctou">
                <option value="San">
            </datalist>

            <div style="padding: 15px; background: #fff3cd; border-radius: 6px; margin-bottom: 20px;">
                <strong>⚠️ Attention :</strong> Les modifications affecteront toutes les futures réservations pour ce trajet.
            </div>

            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <a href="{{ path('admin_trajets') }}" class="btn btn-danger">
                    <i class="fas fa-times"></i> Annuler
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save"></i> Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<style>
.checkbox-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 15px;
    background: #f5f5f5;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s;
    font-weight: 500;
}

.checkbox-label:hover {
    background: #e0e0e0;
}

.checkbox-label input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
}

.checkbox-label input[type="checkbox"]:checked ~ span {
    color: #14B53A;
    font-weight: 700;
}
</style>
{% endblock %}
