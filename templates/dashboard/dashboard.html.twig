{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin - MAYA{% endblock %}

{% block body %}
<!-- Navbar -->
<nav class="main-header navbar navbar-expand navbar-white navbar-light">
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#"><i class="fas fa-bars"></i></a>
        </li>
    </ul>
    <ul class="navbar-nav ml-auto">
        <li class="nav-item">
            <a class="nav-link" href="{{ path('app_logout') }}">
                <i class="fas fa-sign-out-alt"></i> Déconnexion
            </a>
        </li>
    </ul>
</nav>

<!-- Sidebar -->
<aside class="main-sidebar sidebar-dark-primary elevation-4">
    <a href="{{ path('admin_dashboard') }}" class="brand-link">
        <i class="fas fa-bus brand-image"></i>
        <span class="brand-text font-weight-light">MAYA ADMIN</span>
    </a>

    <div class="sidebar">
        <nav class="mt-2">
            <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview">
                <li class="nav-item">
                    <a href="{{ path('admin_dashboard') }}" class="nav-link active">
                        <i class="nav-icon fas fa-tachometer-alt"></i>
                        <p>Dashboard</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_companies') }}" class="nav-link">
                        <i class="nav-icon fas fa-building"></i>
                        <p>Compagnies</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_trips') }}" class="nav-link">
                        <i class="nav-icon fas fa-route"></i>
                        <p>Trajets</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_reservations') }}" class="nav-link">
                        <i class="nav-icon fas fa-ticket-alt"></i>
                        <p>Réservations</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_commissions') }}" class="nav-link">
                        <i class="nav-icon fas fa-money-bill-wave"></i>
                        <p>Commissions</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_statistics') }}" class="nav-link">
                        <i class="nav-icon fas fa-chart-bar"></i>
                        <p>Statistiques</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('admin_users') }}" class="nav-link">
                        <i class="nav-icon fas fa-users"></i>
                        <p>Utilisateurs</p>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</aside>

<!-- Content -->
<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <h1 class="m-0">Dashboard Administrateur</h1>
        </div>
    </div>

    <div class="content">
        <div class="container-fluid">
            <!-- Statistiques -->
            <div class="row">
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-success">
                        <div class="inner">
                            <h3>{{ total_reservations }}</h3>
                            <p>Réservations</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-ticket-alt"></i>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-6">
                    <div class="small-box bg-info">
                        <div class="inner">
                            <h3>{{ (total_revenue / 1000000)|number_format(1) }}M</h3>
                            <p>Revenus (FCFA)</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-money-bill-wave"></i>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-6">
                    <div class="small-box bg-warning">
                        <div class="inner">
                            <h3>{{ (total_commission / 1000)|number_format(0) }}K</h3>
                            <p>Commissions (FCFA)</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-percentage"></i>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-6">
                    <div class="small-box bg-danger">
                        <div class="inner">
                            <h3>{{ total_companies }}</h3>
                            <p>Compagnies</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-building"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dernières réservations -->
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Dernières Réservations</h3>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Référence</th>
                                        <th>Passager</th>
                                        <th>Trajet</th>
                                        <th>Compagnie</th>
                                        <th>Prix</th>
                                        <th>Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for reservation in recent_reservations %}
                                    <tr>
                                        <td>{{ reservation.reservationId }}</td>
                                        <td>{{ reservation.passengerFullName }}</td>
                                        <td>{{ reservation.trip.departureCity }} → {{ reservation.trip.arrivalCity }}</td>
                                        <td>{{ reservation.company.companyName }}</td>
                                        <td>{{ reservation.totalPrice|number_format(0, ',', ' ') }} FCFA</td>
                                        <td>
                                            <span class="badge badge-{{ reservation.status == 'confirmed' ? 'success' : 'warning' }}">
                                                {{ reservation.status }}
                                            </span>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}